    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.1.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "private": true
