{
  "name": "moodmap",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "industrial-add": "npx tsx scripts/industrial_add.ts",
    "industrial-sync": "npx tsx scripts/audit_registry.ts --slug=$npm_config_slug && npx tsx scripts/sync_to_supabase.ts --slug=$npm_config_slug && npx tsx scripts/migrate_media.ts --slug=$npm_config_slug && npx tsx scripts/inject_data.ts && npx tsx scripts/enrich_data.ts --slug=$npm_config_slug && npx tsx scripts/compile_registry.ts",
    "audit-registry": "npx tsx scripts/audit_registry.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
